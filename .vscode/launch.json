{
    "version": "0.2.0",
    "configurations": [
        // ── Run the current file (quick debug) ──────────────────────────
        {
            "name": "Debug Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/.env",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "justMyCode": false
        },

        // ── FastAPI Server (main entry point) ───────────────────────────
        // Launch uvicorn via debugpy so breakpoints work on incoming requests.
        // Hit your endpoints from Postman at http://localhost:8000/api/v1/...
        {
            "name": "Debug API Server (uvicorn)",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "main.main:app",
                "--host", "0.0.0.0",
                "--port", "8000",
                "--reload"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/.env",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "justMyCode": false
        },

        // ── Phase 0+1 CLI: Fault Bucketing + Metrics Extraction ────────
        {
            "name": "Debug Phase 0+1 CLI (bucketing + extraction)",
            "type": "debugpy",
            "request": "launch",
            "module": "main.cli.run_bucketing_and_extraction_pipeline",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/.env",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "justMyCode": false,
            "args": [
                "--trace-file", "${workspaceFolder}/data/traces_sorted.json",
                "--output-dir", "${workspaceFolder}/data/new_reports",
                "--batch-size", "5"
            ]
        },

        // ── Phase 2+3 CLI: Aggregation + Certification ─────────────────
        {
            "name": "Debug Phase 2+3 CLI (aggregation + certification)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/run_aggregation_and_certification_pipeline.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/.env",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "justMyCode": false,
            "args": [
                "--metrics-dir", "${workspaceFolder}/data/output/12-05-26-sequential-aarya-30run",
                "--output-dir", "${workspaceFolder}/data/output/12-05-26-sequential-aarya-30run/certification",
                "--agent-id", "aarya",
                "--agent-name", "Aarya",
                "--runs-per-fault", "30",
                "--debug"
            ]
        },

        // ── Full Certification Pipeline (Phase 0+1+2+3) ─────────────────
        {
            "name": "Debug Full Certification Pipeline",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/run_full_certification_pipeline.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/.env",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "justMyCode": false,
            "args": [
                "--metrics-dir", "${workspaceFolder}/data/output/12-05-26-sequential-aarya-30run",
                "--output-dir", "${workspaceFolder}/data/output/12-05-26-sequential-aarya-30run/certification",
                "--agent-id", "1960bc89-361a-4fcb-af86-699113f09ec9",
                "--agent-name", "demoinfra2",
                "--runs-per-fault", "30",
                "--debug"
            ]
        },

        // ── Tests (pytest) ──────────────────────────────────────────────
        {
            "name": "Debug Tests (pytest)",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/.env",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "justMyCode": false,
            "args": [
                "-xvs"
            ]
        },

        // ── Tests (specific module — edit args as needed) ───────────────
        {
            "name": "Debug Tests (specific module)",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/.env",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "justMyCode": false,
            "args": [
                "-xvs",
                "${input:testPath}"
            ]
        }
    ],
    "inputs": [
        {
            "id": "testPath",
            "type": "promptString",
            "description": "Test path (e.g. fault_analyzer/tests/ or a specific file)",
            "default": "fault_analyzer/tests/"
        }
    ]
}