{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [

        {
            "name": "Run Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "envFile": "${workspaceFolder}/.env"
        },
        {
            "name": "Run multi-fault trace generation",
            "type": "debugpy",
            "request": "launch",
            "module": "multi_fault_trace_generation.main",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/.env",
            "args": [
                "--faults-file", "${workspaceFolder}/multi_fault_trace_generation/config/fault_file.json",
                "--output-dir", "${workspaceFolder}/data/langfuse_minio_traces/multi_fault/",
                "--num-traces", "5",
                "--num-cycles", "3",
                "--agent-name", "Flash",
                "--agent-id", "flash-001-abc123",
                "--agent-description", "An ITOPs agent deployed in a Kubernetes cluster, responsible for monitoring the application's health and performance, and taking corrective actions to ensure optimal operation."
            ]
        },
        {
            "name": "Run fault bucketing (scripts)",
            "type": "debugpy",
            "request": "launch",
            "module": "fault_analyzer.scripts.fault_bucketing",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/.env",
            "args": [
                "--trace-file", "${workspaceFolder}/data/traces_sorted.json",
                "--output-dir", "${workspaceFolder}/data/new_reports",
                "--batch-size", "15"
            ]
        },
        {
            "name": "Run metric extraction (scripts)",
            "type": "debugpy",
            "request": "launch",
            "module": "metric_extraction.scripts.metrics_extractor_from_trace",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/.env",
            "args": [
                "--trace-file-name", "${workspaceFolder}/data/new_reports/traces_sorted_bucket_disk-fill.json",
            ]
        },
        {
            "name": "Run fault bucketing and metric extraction pipeline",
            "type": "debugpy",
            "request": "launch",
            "module": "run_bucketing_and_extraction_pipeline",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/.env",
            "args": [
                "--trace-file", "${workspaceFolder}/data/traces_sorted.json",
                "--output-dir", "${workspaceFolder}/data/new_reports",
                "--store"
            ]
        },
        {
            "name": "Run aggregation (scripts)",
            "type": "debugpy",
            "request": "launch",
            "module": "aggregation.scripts.aggregation",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/.env",
            "args": [
                "--agent-id", "flash-001-abc123",
                "--agent-name", "Flash",
                "--source", "directory",
                "--directory", "${workspaceFolder}/data/new_reports/metrics",
                "--output-path", "${workspaceFolder}/data/new_reports/aggregated/"
            ]
        },
        {
            "name": "Run aggregation and certification pipeline",
            "type": "debugpy",
            "request": "launch",
            "module": "run_aggregation_and_certification_pipeline",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/.env",
            "args": [
                "--metrics-dir", "${workspaceFolder}/data/new_reports/metrics",
                "--output-dir", "${workspaceFolder}/data/new_reports/certification",
                "--agent-id", "flash-001-abc123",
                "--agent-name", "Flash",
                "--debug"
            ]
        }
    ]
}