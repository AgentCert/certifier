# =============================================================================
# AgentCert – Environment Variables
#
# Copy this file to .env and fill in all values before running the application.
# Variables marked REQUIRED must be set; all others have working defaults.
#
# How ConfigLoader resolves ENV_ values:
#   configs/configs.json stores config values as "ENV_<NAME>".
#   ConfigLoader strips the "ENV_" prefix and reads the env var <NAME>.
#   So "ENV_AZURE_OPENAI_API_KEY" in JSON → reads env var AZURE_OPENAI_API_KEY.
# =============================================================================


# -----------------------------------------------------------------------------
# MongoDB                                                          [REQUIRED]
# -----------------------------------------------------------------------------
# Used by both the API layer (settings.py) and the pipeline modules (configs.json).
# With auth:        mongodb://admin:<password>@localhost:27017/?authSource=admin
# Without auth:     mongodb://localhost:27017/agentcert
# Docker Compose:   mongodb://mongo:27017/agentcert
MONGODB_CONNECTION_STRING=mongodb://localhost:27017/agentcert

# Optional overrides (defaults shown)
MONGODB_DATABASE=agentcert


# -----------------------------------------------------------------------------
# API Server                                                       [optional]
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000

# Maximum simultaneous bucketing-extraction pipeline runs (Phase 0+1)
API_MAX_CONCURRENT_TASKS=4

# Maximum simultaneous aggregation-certification pipeline runs (Phase 2+3)
# Lower default because cert runs are significantly heavier than bucketing runs
API_MAX_CONCURRENT_CERT_TASKS=2


# -----------------------------------------------------------------------------
# MongoDB Collection Names                                         [optional]
# -----------------------------------------------------------------------------
# Bucketing-extraction task tracking
API_TASK_COLLECTION=pipeline_tasks

# Aggregation-certification task tracking
CERT_TASK_COLLECTION=certification_tasks

# One document per completed certification run
CERT_METADATA_COLLECTION=certification_metadata

# One document per fault category per certification run
AGG_CATEGORY_COLLECTION=aggregated_category_metadata


# -----------------------------------------------------------------------------
# Workspace Directories                                            [optional]
# -----------------------------------------------------------------------------
# Root directory for per-run trace + metrics output (Phase 0+1)
WORKSPACE_DIR=workspace

# Root directory for aggregated scorecard + certification report output (Phase 2+3)
CERT_WORKSPACE_DIR=workspace/cert


# -----------------------------------------------------------------------------
# Azure OpenAI — Extraction Model (standard, e.g. GPT-4o)         [REQUIRED]
# Referenced in configs.json as ENV_AZURE_OPENAI_*
# -----------------------------------------------------------------------------
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_CHAT_DEPLOYMENT_NAME=


# -----------------------------------------------------------------------------
# Azure OpenAI — Reasoning Model (o-series, e.g. o1 / o3-mini)    [REQUIRED]
# Referenced in configs.json as ENV_AZURE_OPENAI_GPT5_*
# Note: AzureLLMClient automatically strips `temperature` for reasoning models.
# -----------------------------------------------------------------------------
AZURE_OPENAI_GPT5_ENDPOINT=
AZURE_OPENAI_GPT5_API_KEY=
AZURE_OPENAI_GPT5_API_VERSION=2024-12-01-preview
AZURE_OPENAI_GPT5_CHAT_DEPLOYMENT_NAME=


# -----------------------------------------------------------------------------
# Azure OpenAI — Embedding Model                                   [REQUIRED]
# Referenced in configs.json as ENV_AZURE_EMBEDDING_*
# -----------------------------------------------------------------------------
AZURE_EMBEDDING_ENDPOINT=
AZURE_EMBEDDING_API_KEY=
AZURE_EMBEDDING_API_VERSION=2024-02-01
AZURE_EMBEDDING_MODEL=


# -----------------------------------------------------------------------------
# Azure Content Safety                                             [optional]
# Used by the pipeline for RAI compliance checks
# -----------------------------------------------------------------------------
AZURE_CONTENT_SAFETY_ENDPOINT=
AZURE_CONTENT_SAFETY_API_KEY=


# -----------------------------------------------------------------------------
# Azure Blob Storage                                               [optional]
# Required only when storage_config.type = "blob_storage" or "hybrid"
# Referenced in configs.json as ENV_AZURE_STORAGE_CONNECTION_STRING
# -----------------------------------------------------------------------------
AZURE_STORAGE_CONNECTION_STRING=


# -----------------------------------------------------------------------------
# Langfuse                                                         [optional]
# Only needed when submitting bucketing-extraction jobs with
# trace_source.type = "langfuse".  Credentials are passed per-request in the
# request body; these vars are provided here for developer convenience
# (e.g. building curl commands or test scripts).
# -----------------------------------------------------------------------------
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=


# -----------------------------------------------------------------------------
# Python Path                                                      [REQUIRED in Docker]
# Must include the project root so that `main`, `utils`, `fault_analyzer`,
# `metrics_extractor`, `aggregator`, and `cert_builder` are all importable.
# When running locally from the repo root: PYTHONPATH=.
# -----------------------------------------------------------------------------
PYTHONPATH=/app
