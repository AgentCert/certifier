# =============================================================================
# AgentCert – Environment Variables (template)
#
# Single source of truth: the monorepo root .env at /srv/projects/ace-monorepo/.env
# certifier/docker-compose.yml loads it via `env_file: ../.env`. This file is
# kept only as a reference for which variables the certifier consumes and what
# their defaults are.
#
# How ConfigLoader resolves ENV_ values:
#   configs/configs.json stores values as "ENV_<NAME>".
#   ConfigLoader strips the "ENV_" prefix and reads env var <NAME>.
#   e.g. "ENV_AZURE_OPENAI_API_KEY" -> reads AZURE_OPENAI_API_KEY.
# =============================================================================


# -----------------------------------------------------------------------------
# MongoDB                                                          [REQUIRED]
# -----------------------------------------------------------------------------
# Used by both the API layer (settings.py) and the pipeline (configs.json).
#
# Host runs:    mongodb://admin:<pw>@<host>:27017/agentcert?authSource=admin
# No auth:      mongodb://localhost:27017/agentcert
# Compose:      auto-overridden to mongodb://mongo:27017/agentcert inside the network
MONGODB_CONNECTION_STRING=mongodb://localhost:27017/agentcert
MONGODB_DATABASE=agentcert


# -----------------------------------------------------------------------------
# API Server                                                       [optional]
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000

# Max simultaneous bucketing-extraction pipeline runs (Phase 0+1)
API_MAX_CONCURRENT_TASKS=4

# Max simultaneous aggregation-certification pipeline runs (Phase 2+3) — heavier
API_MAX_CONCURRENT_CERT_TASKS=2


# -----------------------------------------------------------------------------
# Host ports for compose-exposed services                          [optional]
# -----------------------------------------------------------------------------
# Override if 27017 / 8081 are already taken on the host.
MONGO_PORT=27017
MONGO_EXPRESS_PORT=8081
MONGO_EXPRESS_USER=admin
MONGO_EXPRESS_PASSWORD=admin


# -----------------------------------------------------------------------------
# MongoDB Collection Names                                         [optional]
# -----------------------------------------------------------------------------
API_TASK_COLLECTION=pipeline_tasks
CERT_TASK_COLLECTION=certification_tasks
CERT_METADATA_COLLECTION=certification_metadata
AGG_CATEGORY_COLLECTION=aggregated_category_metadata


# -----------------------------------------------------------------------------
# Workspace Directories                                            [optional]
# -----------------------------------------------------------------------------
# Inside the container compose remaps these to /app/workspace and /app/workspace/cert
WORKSPACE_DIR=workspace
CERT_WORKSPACE_DIR=workspace/cert


# -----------------------------------------------------------------------------
# Azure OpenAI — Extraction Model (configs.json -> models.gpt-4o)  [REQUIRED]
# Standard model (e.g. GPT-4o). Referenced in configs.json as ENV_AZURE_OPENAI_*.
# -----------------------------------------------------------------------------
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_CHAT_DEPLOYMENT_NAME=


# -----------------------------------------------------------------------------
# Azure OpenAI — Reasoning Model (configs.json -> models.gpt-5.2)  [REQUIRED]
# o-series (o1 / o3-mini / gpt-5.2). AzureLLMClient detects model_type=reasoning
# and strips `temperature` automatically. If you don't have a dedicated o-series
# deployment yet, point these at the same Azure resource as the extraction model.
# -----------------------------------------------------------------------------
AZURE_OPENAI_GPT5_ENDPOINT=
AZURE_OPENAI_GPT5_API_KEY=
AZURE_OPENAI_GPT5_API_VERSION=2024-12-01-preview
AZURE_OPENAI_GPT5_CHAT_DEPLOYMENT_NAME=


# -----------------------------------------------------------------------------
# Azure OpenAI — Embedding Model (configs.json -> models.embedding_model)
# Required when MongoDB vector search / RAGAS is enabled.
# -----------------------------------------------------------------------------
AZURE_EMBEDDING_ENDPOINT=
AZURE_EMBEDDING_API_KEY=
AZURE_EMBEDDING_API_VERSION=2024-02-01
AZURE_EMBEDDING_MODEL=


# -----------------------------------------------------------------------------
# Azure Content Safety                                             [optional]
# Used by the pipeline for RAI compliance checks.
# -----------------------------------------------------------------------------
AZURE_CONTENT_SAFETY_ENDPOINT=
AZURE_CONTENT_SAFETY_API_KEY=


# -----------------------------------------------------------------------------
# Azure Blob Storage                                               [optional]
# Required only when storage_config.type = "blob_storage" or "hybrid"
# (configs.json -> storage_connections.connection_str = ENV_AZURE_STORAGE_CONNECTION_STRING)
# -----------------------------------------------------------------------------
AZURE_STORAGE_CONNECTION_STRING=


# -----------------------------------------------------------------------------
# Langfuse                                                         [optional]
# Required when submitting bucketing-extraction jobs with trace_source.type = "langfuse".
# Credentials are read from env at launch — NOT accepted in the request body.
# -----------------------------------------------------------------------------
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=


# -----------------------------------------------------------------------------
# Python Path                                            [REQUIRED in Docker]
# Must include the project root so all top-level packages are importable.
# Local from repo root: PYTHONPATH=.
# Inside the container: PYTHONPATH=/app
# -----------------------------------------------------------------------------
PYTHONPATH=/app
